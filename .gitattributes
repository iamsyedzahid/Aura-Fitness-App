# Set the default behavior to handle all files as text and force LF on checkout
* text=auto

# Explicitly declare text files you want to always be LF or CRLF
*.py text eol=lf
*.tsx text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.json text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
